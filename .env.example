# Copy this file to .env.local and fill in your own keys.
# .env.local is gitignored — never commit real secrets.

# Apify — used by the extract API route and test-apify.mjs
APIFY_API_TOKEN=

# ZeroBounce — email verification (src/app/api/extract)
ZEROBOUNCE_API_KEY=

# Hunter.io — used by test-hunter.mjs
HUNTER_API_KEY=

# Google API key — used by test-google-api.mjs
GOOGLE_API_KEY=
